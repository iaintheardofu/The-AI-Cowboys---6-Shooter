# ============================================================================
# Yield Daemon — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ============================================================================

# --- Chain Configuration ---------------------------------------------------
YIELD_CHAIN=solana
YIELD_RPC_URL=https://api.mainnet-beta.solana.com
# For Solana: use a paid RPC for speed (Helius, Triton, QuickNode)
# YIELD_RPC_URL=https://rpc.helius.xyz/?api-key=YOUR_KEY

# --- Wallet ----------------------------------------------------------------
YIELD_WALLET_ADDRESS=
YIELD_WALLET_KEYPAIR=/path/to/keypair.json

# --- Stablecoin Target -----------------------------------------------------
YIELD_STABLECOIN=USDC
# Solana USDC mint:
YIELD_STABLECOIN_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# --- Thresholds (tune these for your risk tolerance) -----------------------
# Minimum SOL profit before swapping to USDC
YIELD_CONSOLIDATION_THRESHOLD=0.05
# Minimum USDC balance before triggering bank transfer
YIELD_OFFRAMP_THRESHOLD=100.0
# Maximum single bank transfer (limits exposure)
YIELD_MAX_OFFRAMP=10000.0
# Slippage tolerance for swaps (basis points, 50 = 0.5%)
YIELD_SLIPPAGE_BPS=50

# --- Exchange (for fiat off-ramp) ------------------------------------------
# Supported: coinbase, kraken
YIELD_EXCHANGE=coinbase

# Coinbase Advanced Trade API:
YIELD_EXCHANGE_API_KEY=
YIELD_EXCHANGE_API_SECRET=
YIELD_EXCHANGE_PASSPHRASE=

# Kraken API (alternative):
# YIELD_EXCHANGE=kraken
# YIELD_EXCHANGE_API_KEY=
# YIELD_EXCHANGE_API_SECRET=

# Bank account ID (from exchange withdrawal settings)
YIELD_BANK_ACCOUNT_ID=

# Fiat currency for withdrawal
YIELD_FIAT_CURRENCY=USD

# --- Daemon State ----------------------------------------------------------
YIELD_STATE_DIR=runtime/yield_daemon
# Check interval (seconds) — how often the off-ramp checks balances
YIELD_CHECK_INTERVAL=300

# --- Safety ----------------------------------------------------------------
# IMPORTANT: Start with dry_run=true to verify everything works
# Only set to false when you're ready to use real money
YIELD_DRY_RUN=true

# --- Jito Bundle Engine (Solana MEV) --------------------------------------
# JITO_BLOCK_ENGINE=https://mainnet.block-engine.jito.wtf
# JITO_AUTH_KEYPAIR=/path/to/jito-auth-keypair.json

# --- EVM Configuration (if using Ethereum/Arbitrum/Base) -------------------
# EVM_PRIVATE_KEY=
# VAULT_CONTRACT=0x...
# SWAP_ROUTER=0x...  # Uniswap V3 Router
